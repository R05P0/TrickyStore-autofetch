id=keybox_autofetch
name=Keybox Autofetch for Tricky Store
version=v1.0.0
versionCode=1
author=R05P0
description=Keeps Tricky Store supplied with a working attestation keybox. On a schedule it checks Google's revocation list, and if the current keybox is revoked it fetches a fresh one (Yurikey/upstream/custom, with failover), validates it, installs it to keybox.xml and notifies you. One-tap Apply re-attests and reboots. Never touches Tricky Store's own module files.
updateJson=https://raw.githubusercontent.com/R05P0/keybox-autofetch/main/update.json
